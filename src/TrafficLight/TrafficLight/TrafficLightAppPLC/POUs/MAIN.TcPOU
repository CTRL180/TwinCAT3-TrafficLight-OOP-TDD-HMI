<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="MAIN" Id="{7d9e93e5-9bb5-44fa-aa35-8d8935fc199d}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
	fbIntersection : FB_Intersection;
    tonAdvance     : TON;                        // timer between phase advances
    PHASE_TIME     : TIME := T#5S;               // how long each phase lasts
    bManualAdvance    : BOOL := FALSE;   		// written by HMI button
    bManualDidAdvance : BOOL := FALSE;   		// did the manual request advance?
    bDoAdvance        : BOOL := FALSE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Manual advance (edge-detected inside the intersection); returns TRUE if it advanced
bManualDidAdvance := fbIntersection.Update(bManualStepRequest := bManualAdvance);
bManualAdvance := FALSE;   // consume the HMI request

// Reset the timer if it elapsed OR a manual advance just happened
bDoAdvance := tonAdvance.Q OR bManualDidAdvance;

// Single timer call: IN goes FALSE on either trigger -> restarts the interval
tonAdvance(IN := NOT bDoAdvance, PT := PHASE_TIME);

// Auto-advance only when the timer itself elapsed
IF (tonAdvance.Q) THEN
    fbIntersection.Advance();
END_IF]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>