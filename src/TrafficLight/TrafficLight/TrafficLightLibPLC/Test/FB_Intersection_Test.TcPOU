<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_Intersection_Test" Id="{c110743a-9204-448b-b4a8-3ebea3fe05df}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Intersection_Test EXTENDS TcUnit.FB_TestSuite
VAR
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[NewIntersectionStartsInAllRed();
IntersectionAdvancesThroughPhasesInOrder();
NorthSouthFlowingShowsNsGreenEwRed();
NeverTwoGreensAcrossFullCycle();
ManualRequestAdvancesPhase();
UpdateReportsTrueWhenItAdvances();
UpdateReportsFalseWithoutEdge();]]></ST>
    </Implementation>
    <Method Name="IntersectionAdvancesThroughPhasesInOrder" Id="{5843715c-18fa-49a6-a054-df0239c4a384}">
      <Declaration><![CDATA[METHOD PRIVATE IntersectionAdvancesThroughPhasesInOrder
VAR
	intersection : FB_Intersection;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('IntersectionAdvancesThroughPhasesInOrder');

// starts AllRed
AssertEquals_INT(
    Expected := TO_INT(E_Phase.AllRed),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'Should start AllRed');

intersection.Advance();           
AssertEquals_INT(
    Expected := TO_INT(E_Phase.NorthSouthFlowing),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'AllRed should advance to NorthSouthFlowing');

intersection.Advance();
AssertEquals_INT(
    Expected := TO_INT(E_Phase.NorthSouthClearing),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'NorthSouthFlowing should advance to NorthSouthClearing');

intersection.Advance();
AssertEquals_INT(
    Expected := TO_INT(E_Phase.EastWestFlowing),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'NorthSouthClearing should advance to EastWestFlowing');

intersection.Advance();
AssertEquals_INT(
    Expected := TO_INT(E_Phase.EastWestClearing),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'EastWestFlowing should advance to EastWestClearing');

intersection.Advance();
AssertEquals_INT(
    Expected := TO_INT(E_Phase.NorthSouthFlowing),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'EastWestClearing should wrap to NorthSouthFlowing (not AllRed)');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="ManualRequestAdvancesPhase" Id="{43bcf4b9-21a6-4af9-86c8-80e7268258b5}">
      <Declaration><![CDATA[METHOD PRIVATE ManualRequestAdvancesPhase
VAR
	intersection : FB_Intersection;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('ManualRequestAdvancesPhase');

// starts in AllRed; simulate a button press (rising edge)
intersection.Update(bManualStepRequest := FALSE);   // establish low baseline
intersection.Update(bManualStepRequest := TRUE);    // rising edge -> advance

AssertEquals_INT(
    Expected := TO_INT(E_Phase.NorthSouthFlowing),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'A manual request should advance out of AllRed');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="NeverTwoGreensAcrossFullCycle" Id="{483527da-3675-4dea-b5ff-c586d75218b1}">
      <Declaration><![CDATA[METHOD PRIVATE NeverTwoGreensAcrossFullCycle
VAR
	intersection : FB_Intersection;
    i            : INT;
    nsGreen      : BOOL;
    ewGreen      : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('NeverTwoGreensAcrossFullCycle');

// Walk several full cycles; the safety rule must hold at every step.
FOR i := 1 TO 12 DO
    intersection.Advance();

    nsGreen := (intersection.NorthSouthState = E_LightState.Green);
    ewGreen := (intersection.EastWestState  = E_LightState.Green);

    AssertFalse(
        Condition := (nsGreen AND ewGreen),
        Message   := 'Both directions must never be green at once');
END_FOR

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="NewIntersectionStartsInAllRed" Id="{70909ec8-d067-4845-976a-244e0c3b0421}">
      <Declaration><![CDATA[METHOD PRIVATE NewIntersectionStartsInAllRed
VAR
	intersection : FB_Intersection;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('NewIntersectionStartsInAllRed');

AssertEquals_INT(
    Expected := TO_INT(E_Phase.AllRed),
    Actual   := TO_INT(intersection.CurrentPhase),
    Message  := 'A new intersection should start in AllRed for safety');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="NorthSouthFlowingShowsNsGreenEwRed" Id="{f2df457c-c78c-4463-bda3-4fad76f93f44}">
      <Declaration><![CDATA[METHOD PRIVATE NorthSouthFlowingShowsNsGreenEwRed
VAR
	intersection : FB_Intersection;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('NorthSouthFlowingShowsNsGreenEwRed');

intersection.Advance();   // AllRed -> NorthSouthFlowing

AssertEquals_INT(
    Expected := TO_INT(E_LightState.Green),
    Actual   := TO_INT(intersection.NorthSouthState),
    Message  := 'NS should be GREEN in NorthSouthFlowing');

AssertEquals_INT(
    Expected := TO_INT(E_LightState.Red),
    Actual   := TO_INT(intersection.EastWestState),
    Message  := 'EW should be RED in NorthSouthFlowing');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="UpdateReportsFalseWithoutEdge" Id="{aace1847-9951-4ad7-b1e7-c15698e09ca9}">
      <Declaration><![CDATA[METHOD PRIVATE UpdateReportsFalseWithoutEdge
VAR
	intersection : FB_Intersection;
    didAdvance   : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('UpdateReportsFalseWithoutEdge');

didAdvance := intersection.Update(bManualStepRequest := FALSE);  // no request

AssertFalse(
    Condition := didAdvance,
    Message   := 'Update should report FALSE when there is no manual request');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="UpdateReportsTrueWhenItAdvances" Id="{beb0b23f-7737-4ef8-b507-a6a2e8881dd7}">
      <Declaration><![CDATA[METHOD PRIVATE UpdateReportsTrueWhenItAdvances
VAR
	intersection : FB_Intersection;
    didAdvance   : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('UpdateReportsTrueWhenItAdvances');

intersection.Update(bManualStepRequest := FALSE);              // baseline low
didAdvance := intersection.Update(bManualStepRequest := TRUE); // rising edge

AssertTrue(
    Condition := didAdvance,
    Message   := 'Update should report TRUE on the scan it advances');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>