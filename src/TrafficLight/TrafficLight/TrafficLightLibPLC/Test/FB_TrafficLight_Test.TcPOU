<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_TrafficLight_Test" Id="{05a59aff-e522-47ed-8604-19fdd813a76a}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_TrafficLight_Test EXTENDS TcUnit.FB_TestSuite
VAR
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[NewLightStartsInRed();
RedLightGoesGreenOnRequest();
GreenLightGoesAmberOnRequest();
LightCyclesThroughFullSequence();]]></ST>
    </Implementation>
    <Method Name="GreenLightGoesAmberOnRequest" Id="{e92e9b0c-4100-4da9-892a-f37d6db31987}">
      <Declaration><![CDATA[METHOD PRIVATE GreenLightGoesAmberOnRequest
VAR
	light       : FB_TrafficLight;
    actualState : E_LightState;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('GreenLightGoesAmberOnRequest');

light.RequestGreen();              // get it to Green first
light.RequestAmber();              
actualState := light.CurrentState;

AssertEquals_INT(
    Expected := TO_INT(E_LightState.Amber),
    Actual   := TO_INT(actualState),
    Message  := 'A GREEN light should go AMBER when requested');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="LightCyclesThroughFullSequence" Id="{f4c079a2-1192-44e8-a91e-ca76b94915f2}">
      <Declaration><![CDATA[METHOD PRIVATE LightCyclesThroughFullSequence
VAR
	light : FB_TrafficLight;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('LightCyclesThroughFullSequence');

// starts in Red
AssertEquals_INT(
    Expected := TO_INT(E_LightState.Red),
    Actual   := TO_INT(light.CurrentState),
    Message  := 'Should start RED');

light.Cycle();                    
AssertEquals_INT(
    Expected := TO_INT(E_LightState.RedAmber),
    Actual   := TO_INT(light.CurrentState),
    Message  := 'Red should advance to RedAmber');

light.Cycle();
AssertEquals_INT(
    Expected := TO_INT(E_LightState.Green),
    Actual   := TO_INT(light.CurrentState),
    Message  := 'RedAmber should advance to Green');

light.Cycle();
AssertEquals_INT(
    Expected := TO_INT(E_LightState.Amber),
    Actual   := TO_INT(light.CurrentState),
    Message  := 'Green should advance to Amber');

light.Cycle();
AssertEquals_INT(
    Expected := TO_INT(E_LightState.Red),
    Actual   := TO_INT(light.CurrentState),
    Message  := 'Amber should wrap back to Red');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="NewLightStartsInRed" Id="{870cd3fb-b52e-4f56-bf23-b9ba4841ad63}">
      <Declaration><![CDATA[METHOD PRIVATE NewLightStartsInRed
VAR
	light       : FB_TrafficLight;
    actualState : E_LightState;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('NewLightStartsInRed');

actualState := light.CurrentState;   // read the property into a variable first

AssertEquals_INT(
    Expected := TO_INT(E_LightState.Red),
    Actual   := TO_INT(actualState),
    Message  := 'A new light should start in RED');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="RedLightGoesGreenOnRequest" Id="{9ffbc1b8-7f1c-42d9-ad91-886f75c1297d}">
      <Declaration><![CDATA[METHOD PRIVATE RedLightGoesGreenOnRequest
VAR
	light       : FB_TrafficLight;
    actualState : E_LightState;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('RedLightGoesGreenOnRequest');

// light starts in Red (verified by the previous test)
light.RequestGreen();             
actualState := light.CurrentState;

AssertEquals_INT(
    Expected := TO_INT(E_LightState.Green),
    Actual   := TO_INT(actualState),
    Message  := 'A light in RED should go GREEN when requested');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>